# DocGuardian AI — backend environment template.
# Copy to ".env" and fill in. The local ingestion + processing pipeline
# runs WITHOUT any of these (no Azure required).

# --- Azure OpenAI (only needed for embeddings + agent reasoning) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# --- Postgres + pgvector ---
DATABASE_URL=postgresql://docguardian:docguardian@localhost:5432/docguardian

# --- Local data layout ---
DATA_DIR=data
