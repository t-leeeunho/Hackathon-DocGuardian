# DocGuardian AI — backend environment template.
# Copy to ".env" and fill in. The local ingestion + processing pipeline
# runs WITHOUT any of these (no Azure required).

# --- Azure OpenAI (only needed for embeddings + agent reasoning) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# --- Chat provider for the Curator/Guardian agents ---
# CHAT_PROVIDER: "azure" (default; /chat + /propose return 503 if Azure is unset),
# "fake" (deterministic offline stand-in for local dev/tests/demo), or
# "auto" (Azure if configured, otherwise the fake).
CHAT_PROVIDER=azure

# --- Postgres + pgvector ---
DATABASE_URL=postgresql://docguardian:docguardian@localhost:5432/docguardian

# --- Embeddings ---
# EMBEDDING_PROVIDER: "local" (fastembed/ONNX, no Azure) or "azure" (Azure OpenAI)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_DIM is auto-detected for local; set explicitly for azure (e.g. 3072)
EMBEDDING_DIM=

# --- Local data layout ---
DATA_DIR=data
